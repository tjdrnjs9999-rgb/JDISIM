{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/payment-complete",
      "dest": "/api/payment-complete.js"
    },
    {
      "src": "/(.*)",
      "headers": {
        "x-robots-tag": "index, follow",
        "x-frame-options": "DENY",
        "x-content-type-options": "nosniff"
      },
      "dest": "/$1"
    }
  ]
}
